            <roundRobin>
                <connectionTTL>5 minutes</connectionTTL>
            </roundRobin>
        </connectionStrategy>
        <writeBufferSize>2048</writeBufferSize>
    </appender>
    -->

    <logger name="com.thesss.platform.gateway" level="${LOG_LEVEL}" additivity="false">
        <appender-ref ref="CONSOLE_JSON"/>
        <appender-ref ref="FILE_JSON"/> <!-- Optional -->
        <!-- <appender-ref ref="LOGSTASH_TCP"/> --> <!-- Optional -->
    </logger>

    <logger name="org.springframework.cloud.gateway" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE_JSON"/>
        <appender-ref ref="FILE_JSON"/> <!-- Optional -->
    </logger>

    <logger name="org.springframework.security" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE_JSON"/>
        <appender-ref ref="FILE_JSON"/> <!-- Optional -->
    </logger>

    <logger name="reactor.netty" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE_JSON"/>
        <appender-ref ref="FILE_JSON"/> <!-- Optional -->
    </logger>
    
    <logger name="io.lettuce.core" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE_JSON"/>
        <appender-ref ref="FILE_JSON"/> <!-- Optional -->
    </logger>

    <logger name="org.springframework.boot.actuate.endpoint.web" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE_JSON"/>
        <appender-ref ref="FILE_JSON"/> <!-- Optional -->
    </logger>

    <root level="${ROOT_LOG_LEVEL}">
        <appender-ref ref="CONSOLE_JSON"/>
        <appender-ref ref="FILE_JSON"/> <!-- Optional -->
        <!-- <appender-ref ref="LOGSTASH_TCP"/> --> <!-- Optional -->
    </root>

</configuration>