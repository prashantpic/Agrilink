<configuration>

    <springProperty scope="context" name="APP_NAME" source="spring.application.name" defaultValue="api-gateway"/>
    <springProperty scope="context" name="LOG_LEVEL_APP" source="logging.level.com.thesss.platform.gateway" defaultValue="DEBUG"/>
    <springProperty scope="context" name="LOG_LEVEL_SPRING_GATEWAY" source="logging.level.org.springframework.cloud.gateway" defaultValue="INFO"/>
    <springProperty scope="context" name="LOG_LEVEL_SPRING_SECURITY" source="logging.level.org.springframework.security" defaultValue="INFO"/>
    <springProperty scope="context" name="LOG_LEVEL_ROOT" source="logging.level.root" defaultValue="INFO"/>

    <property name="LOG_DIR" value="${LOG_PATH:-./logs}"/>
    <property name="LOG_FILE_NAME" value="${APP_NAME}"/>

    <appender name="CONSOLE_JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeMdcKeyName>correlationId</includeMdcKeyName>
            <includeMdcKeyName>traceId</includeMdcKeyName>
            <includeMdcKeyName>spanId</includeMdcKeyName>
            <includeMdcKeyName>parentId</includeMdcKeyName> <!-- For Sleuth-like tracing -->
            <customFields>{"application_name":"${APP_NAME}"}</customFields>
            <fieldNames>
                <timestamp>timestamp</timestamp>
                <version>[ignore]</version> <!-- Omit default @version field -->
                <level>level</level>
                <thread>thread</thread>
                <logger>logger</logger>
                <message>message</message>
                <stackTrace>stack_trace</stackTrace>
            </fieldNames>
        </encoder>
    </appender>

    <!-- Example File Appender with JSON -->
    <appender name="FILE_JSON" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/${LOG_FILE_NAME}.log.json</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/${LOG_FILE_NAME}.%d{yyyy-MM-dd}.log.json.gz</fileNamePattern>
            <maxHistory>30</maxHistory> <!-- days to keep -->
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeMdcKeyName>correlationId</includeMdcKeyName>
            <includeMdcKeyName>traceId</includeMdcKeyName>
            <includeMdcKeyName>spanId</includeMdcKeyName>
            <includeMdcKeyName>parentId</includeMdcKeyName>
            <customFields>{"application_name":"${APP_NAME}"}</customFields>
            <fieldNames>
                <timestamp>timestamp</timestamp>
                <version>[ignore]</version>
                <level>level</level>
                <thread>thread</thread>
                <logger>logger</logger>
                <message>message</message>
                <stackTrace>stack_trace</stackTrace>
            </fieldNames>
        </encoder>
    </appender>

    <!-- Example Logstash Appender (TCP)
    <appender name="LOGSTASH_TCP" class="net.logstash.logback.appender.LogstashTcpSocketAppender">
        <destination>${LOGSTASH_DESTINATION:-localhost:5044}</destination>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeMdcKeyName>correlationId</includeMdcKeyName>
            <includeMdcKeyName>traceId</includeMdcKeyName>
            <includeMdcKeyName>spanId</includeMdcKeyName>
            <includeMdcKeyName>parentId</includeMdcKeyName>
            <customFields>{"application_name":"${APP_NAME}"}</customFields>
        </encoder>
        <keepAliveDuration>5 minutes</keepAliveDuration>
    </appender>
    -->

    <root level="${LOG_LEVEL_ROOT}">
        <appender-ref ref="CONSOLE_JSON"/>
        <appender-ref ref="FILE_JSON"/>
        <!-- <appender-ref ref="LOGSTASH_TCP"/> -->
    </root>

    <logger name="com.thesss.platform.gateway" level="${LOG_LEVEL_APP}" additivity="false">
        <appender-ref ref="CONSOLE_JSON"/>
        <appender-ref ref="FILE_JSON"/>
        <!-- <appender-ref ref="LOGSTASH_TCP"/> -->
    </logger>

    <logger name="org.springframework.cloud.gateway" level="${LOG_LEVEL_SPRING_GATEWAY}" additivity="false">
        <appender-ref ref="CONSOLE_JSON"/>
        <appender-ref ref="FILE_JSON"/>
        <!-- <appender-ref ref="LOGSTASH_TCP"/> -->
    </logger>

    <logger name="org.springframework.security" level="${LOG_LEVEL_SPRING_SECURITY}" additivity="false">
        <appender-ref ref="CONSOLE_JSON"/>
        <appender-ref ref="FILE_JSON"/>
        <!-- <appender-ref ref="LOGSTASH_TCP"/> -->
    </logger>

    <logger name="reactor.netty.http.client" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE_JSON"/>
        <appender-ref ref="FILE_JSON"/>
    </logger>

    <logger name="io.lettuce.core" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE_JSON"/>
        <appender-ref ref="FILE_JSON"/>
    </logger>

    <!-- Suppress excessive logging from Spring Boot Actuator health checks in Eureka client -->
    <logger name="com.netflix.discovery.shared.transport.decorator.RedirectingEurekaHttpClient" level="WARN"/>
    <logger name="com.netflix.discovery.DiscoveryClient" level="WARN"/>

</configuration>