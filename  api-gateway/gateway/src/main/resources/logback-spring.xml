<configuration>

    <springProperty scope="context" name="APP_NAME" source="spring.application.name" defaultValue="api-gateway"/>
    <springProperty scope="context" name="LOG_LEVEL" source="logging.level.com.thesss.platform.gateway" defaultValue="DEBUG"/>
    <springProperty scope="context" name="ROOT_LOG_LEVEL" source="logging.level.root" defaultValue="INFO"/>

    <property name="LOG_DIR" value="${LOG_PATH:-logs}"/>
    <property name="LOG_FILE_NAME" value="${APP_NAME}"/>

    <contextName>${APP_NAME}</contextName>

    <appender name="CONSOLE_JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeCallerData>false</includeCallerData>
            <customFields>{"application_name":"${APP_NAME}"}</customFields>
            <fieldNames>
                <timestamp>timestamp</timestamp>
                <version>[ignore]</version> <!-- Omit default @version field -->
                <level>level</level>
                <thread>thread</thread>
                <logger>logger</logger>
                <message>message</message>
                <stackTrace>stack_trace</stackTrace>
                <context/> <!-- Include contextName -->
            </fieldNames>
            <!-- Add MDC fields like traceId, spanId -->
            <mdcKeys>
                <key>traceId</key>
                <key>spanId</key>
                <key>correlationId</key> <!-- Generic correlation ID -->
                <key>X-Request-ID</key>
                <key>X-B3-TraceId</key>
                <key>X-B3-SpanId</key>
            </mdcKeys>
        </encoder>
    </appender>

    <!-- Optional: File Appender with JSON -->
    <appender name="FILE_JSON" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/${LOG_FILE_NAME}.json.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/${LOG_FILE_NAME}.json.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
            <maxHistory>30</maxHistory> <!-- Keep 30 days of history -->
            <totalSizeCap>1GB</totalSizeCap> <!-- Total size of all archive files -->
        </rollingPolicy>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeCallerData>false</includeCallerData>
            <customFields>{"application_name":"${APP_NAME}"}</customFields>
            <fieldNames>
                <timestamp>timestamp</timestamp>
                <version>[ignore]</version>
                <level>level</level>
                <thread>thread</thread>
                <logger>logger</logger>
                <message>message</message>
                <stackTrace>stack_trace</stackTrace>
                <context/>
            </fieldNames>
            <mdcKeys>
                <key>traceId</key>
                <key>spanId</key>
                <key>correlationId</key>
                <key>X-Request-ID</key>
                <key>X-B3-TraceId</key>
                <key>X-B3-SpanId</key>
            </mdcKeys>
        </encoder>
    </appender>

    <!-- Optional: Logstash TCP Appender for centralized logging -->
    <!--
    <appender name="LOGSTASH_TCP" class="net.logstash.logback.appender.LogstashTcpSocketAppender">
        <destination>${LOGSTASH_DESTINATION:-localhost:5000}</destination>
