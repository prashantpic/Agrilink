# environments/dev/secrets.tfvars.example
# Template for sensitive environment variables for the 'dev' environment.
# The actual 'secrets.tfvars' file containing real secrets IS NOT COMMITTED to version control.
# It should be created locally or injected securely via CI/CD.
# REQ-8-011: This file guides secure configuration.

# --- RDS Master Password ---
# Replace with the actual master password for the RDS/Aurora database in dev.
# rds_master_password = "your_strong_dev_db_password_here"

# --- Grafana Admin Password ---
# Replace with the actual admin password for Grafana in dev.
# grafana_admin_password = "your_strong_dev_grafana_password_here"

# --- Other Potential Secrets ---
# If your application or infrastructure modules require other sensitive inputs,
# define them here as examples.

# Example API Key for an external service used in dev
# external_service_api_key = "dev_api_key_for_xyz_service"

# Example OAuth client secret for an identity provider integration
# oauth_client_secret = "very_secret_oauth_client_secret_dev"