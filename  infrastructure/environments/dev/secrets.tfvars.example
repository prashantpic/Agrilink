# environments/dev/secrets.tfvars.example
# Purpose: Template for sensitive environment variables, guiding secure configuration.
# The actual 'secrets.tfvars' is gitignored and securely managed.
# LogicDescription: Shows placeholders for database passwords, API keys, and other sensitive credentials
# required by the 'dev' environment. The actual 'secrets.tfvars' file containing real secrets is
# not committed to version control and is typically injected via CI/CD secure variables or a secrets management tool.
# ImplementedFeatures: Dev Secrets Placeholder Definition
# RequirementIds: REQ-8-011

# This file is an example. DO NOT COMMIT ACTUAL SECRETS HERE.
# Create a 'secrets.tfvars' file (gitignored) or inject these values via CI/CD.

# Example: RDS Master Password (if not generated by secrets_manager module and you need to provide it)
# rds_master_password = "your_super_secret_dev_db_password"

# Example: API Key for an external service used in dev
# external_service_api_key = "dev_api_key_value"

# Example: Grafana Admin Password (if not managed by secrets_manager module and needs to be set here)
# grafana_admin_password = "your_dev_grafana_admin_password"

# Note: For many secrets, it's best practice to have the secrets_manager module generate them
# (like rds_master_password) or to load them into AWS Secrets Manager out-of-band and reference their ARNs.
# This file would then be used for secrets that Terraform *itself* needs during `apply` for resource creation,
# which are not already in AWS Secrets Manager prior to the `apply`.