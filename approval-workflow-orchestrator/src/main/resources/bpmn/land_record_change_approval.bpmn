```xml
<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_LandChange" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.20.0">
  <bpmn:process id="landRecordChangeApprovalProcess" name="Land Record Change Approval Process" isExecutable="true">
    <bpmn:documentation>Manages the approval process for modifications to land records.</bpmn:documentation>
    <bpmn:startEvent id="StartEvent_LandChangeApproval" name="Land Record Change Submitted">
      <bpmn:outgoing>Flow_To_AssignLandApprover</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="UserTask_AssignLandApprover" name="Assign Land Record Approver" camunda:candidateGroups="landRecordApprovers">
      <bpmn:documentation>A user with the 'landRecordApprovers' group claims this task to review and assign a specific approver or can directly approve if authorized.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:taskListener event="create" class="com.thesss.platform.workflows.listeners.UserTaskAssignmentListener" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_To_AssignLandApprover</bpmn:incoming>
      <bpmn:outgoing>Flow_To_LandApproverReview</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="UserTask_LandApproverReview" name="Review Land Record Change">
      <bpmn:documentation>Approver reviews the land record change details and makes a decision.</bpmn:documentation>
      <bpmn:incoming>Flow_To_LandApproverReview</bpmn:incoming>
      <bpmn:outgoing>Flow_To_LandDecisionGateway</bpmn:outgoing>
      <bpmn:extensionElements>
        <camunda:formData>
          <camunda:formField id="isApproved" label="Approve Change?" type="boolean" />
          <camunda:formField id="approvalComments" label="Approval Comments" type="string" />
        </camunda:formData>
        <camunda:taskListener event="complete" delegateExpression="${setApprovalOutcomeDelegate}" />
      </bpmn:extensionElements>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_LandDecision" name="Approved?">
      <bpmn:incoming>Flow_To_LandDecisionGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_To_UpdateLandStatusApproved</bpmn:outgoing>
      <bpmn:outgoing>Flow_To_UpdateLandStatusRejected</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="ServiceTask_UpdateLandStatusApproved" name="Update Land Record Status to Approved" camunda:delegateExpression="${updateLandRecordStatusCommandDelegate}">
      <bpmn:incoming>Flow_To_UpdateLandStatusApproved</bpmn:incoming>
      <bpmn:outgoing>Flow_To_LogLandHistoryApproved</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="ServiceTask_LogLandHistoryApproved" name="Log Land Approval History" camunda:delegateExpression="${logLandApprovalHistoryDelegate}">
      <bpmn:incoming>Flow_To_LogLandHistoryApproved</bpmn:incoming>
      <bpmn:outgoing>Flow_To_NotifyLandSubmitterApproved</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="ServiceTask_NotifyLandSubmitterApproved" name="Notify Submitter of Approval" camunda:delegateExpression="${sendWorkflowStatusUpdateNotificationDelegate}">
      <bpmn:incoming>Flow_To_NotifyLandSubmitterApproved</bpmn:incoming>
      <bpmn:outgoing>Flow_To_EndLandApproved</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_LandChangeApproved" name="Land Record Change Approved">
      <bpmn:incoming>Flow_To_EndLandApproved</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="ServiceTask_UpdateLandStatusRejected" name="Update Land Record Status to Rejected" camunda:delegateExpression="${updateLandRecordStatusCommandDelegate}">
      <bpmn:incoming>Flow_To_UpdateLandStatusRejected</bpmn:incoming>
      <bpmn:outgoing>Flow_To_LogLandHistoryRejected</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="ServiceTask_LogLandHistoryRejected" name="Log Land Rejection History" camunda:delegateExpression="${logLandApprovalHistoryDelegate}">
      <bpmn:incoming>Flow_To_LogLandHistoryRejected</bpmn:incoming>
      <bpmn:outgoing>Flow_To_NotifyLandSubmitterRejected</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="ServiceTask_NotifyLandSubmitterRejected" name="Notify Submitter of Rejection" camunda:delegateExpression="${sendWorkflowStatusUpdateNotificationDelegate}">
      <bpmn:incoming>Flow_To_NotifyLandSubmitterRejected</bpmn:incoming>
      <bpmn:outgoing>Flow_To_EndLandRejected</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_LandChangeRejected" name="Land Record Change Rejected">
      <bpmn:incoming>Flow_To_EndLandRejected</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_To_AssignLandApprover" sourceRef="StartEvent_LandChangeApproval" targetRef="UserTask_AssignLandApprover" />
    <bpmn:sequenceFlow id="Flow_To_LandApproverReview" sourceRef="UserTask_AssignLandApprover" targetRef="UserTask_LandApproverReview" />
    <bpmn:sequenceFlow id="Flow_To_LandDecisionGateway" sourceRef="UserTask_LandApproverReview" targetRef="Gateway_LandDecision" />
    <bpmn:sequenceFlow id="Flow_To_UpdateLandStatusApproved" name="Yes" sourceRef="Gateway_LandDecision" targetRef="ServiceTask_UpdateLandStatusApproved">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${isApproved == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_To_LogLandHistoryApproved" sourceRef="ServiceTask_UpdateLandStatusApproved" targetRef="ServiceTask_LogLandHistoryApproved" />
    <bpmn:sequenceFlow id="Flow_To_NotifyLandSubmitterApproved" sourceRef="ServiceTask_LogLandHistoryApproved" targetRef="ServiceTask_NotifyLandSubmitterApproved" />
    <bpmn:sequenceFlow id="Flow_To_EndLandApproved" sourceRef="ServiceTask_NotifyLandSubmitterApproved" targetRef="EndEvent_LandChangeApproved" />
    <bpmn:sequenceFlow id="Flow_To_UpdateLandStatusRejected" name="No" sourceRef="Gateway_LandDecision" targetRef="ServiceTask_UpdateLandStatusRejected">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${isApproved == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_To_LogLandHistoryRejected" sourceRef="ServiceTask_UpdateLandStatusRejected" targetRef="ServiceTask_LogLandHistoryRejected" />
    <bpmn:sequenceFlow id="Flow_To_NotifyLandSubmitterRejected" sourceRef="ServiceTask_LogLandHistoryRejected" targetRef="ServiceTask_NotifyLandSubmitterRejected" />
    <bpmn:sequenceFlow id="Flow_To_EndLandRejected" sourceRef="ServiceTask_NotifyLandSubmitterRejected" targetRef="EndEvent_LandChangeRejected" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_LandChange">
    <bpmndi:BPMNPlane id="BPMNPlane_LandChange" bpmnElement="landRecordChangeApprovalProcess">
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
```